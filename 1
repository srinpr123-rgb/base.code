// GitHub App: "Custom Network" - Updated BlockDAG Mainnet Configuration
// Verified as of March 15, 2026


const bdagMainnet = {
  chainId: '0x57C', // Hexadecimal for 1404
  chainName: 'BlockDAG Mainnet',
  nativeCurrency: {
    name: 'BlockDAG',
    symbol: 'BDAG',
    decimals: 18
  },
  rpcUrls: ['https://rpc.bdagscan.com/'],
  blockExplorerUrls: ['https://bdagscan.com/']
};

async function syncBlockDAGNetwork() {
  if (window.ethereum) {
    try {
      // Attempt to switch to the BlockDAG network
      await window.ethereum.request({
        method: 'wallet_switchEthereumChain',
        params: [{ chainId: bdagMainnet.chainId }],
      });
      console.log("Successfully switched to BlockDAG Mainnet.");
    } catch (switchError) {
      // If the network is not added to the wallet, add it
      if (switchError.code === 4902) {
        try {
          await window.ethereum.request({
            method: 'wallet_addEthereumChain',
            params: [bdagMainnet],
          });
          console.log("BlockDAG Mainnet added and synchronized.");
        } catch (addError) {
          console.error("User rejected network addition:", addError);
        }
      }
    }
  } else {
    alert("Web3 provider not detected. Please ensure your wallet is active.");
  }
}


