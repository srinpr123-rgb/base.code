(async () => {
    if (window.ethereum) {
        try {
            await window.ethereum.request({
                method: 'wallet_addEthereumChain',
                params: [{
                    chainId: '0x57C', // 1404 in Hex
                    chainName: 'BlockDAG Mainnet',
                    nativeCurrency: {
                        name: 'BlockDAG',
                        symbol: 'BDAG',
                        decimals: 18
                    },
                    rpcUrls: ['https://rpc.bdagscan.com'],
                    blockExplorerUrls: ['https://bdagscan.com']
                }]
            });
            console.log("BlockDAG Network request sent to wallet.");
        } catch (error) {
            console.error("Connection failed:", error);
        }
    } else {
        console.error("No Web3 wallet detected. Please ensure your extension is active.");
    }
})();
